# Optional. Copy this file to .env and fill in real values. Never commit .env.
# A .env is NOT required -- the tool runs without one (PubMed just uses a lower
# rate limit). An NCBI API key raises the E-utilities rate limit.
NCBI_API_KEY=
# Optional: contact email NCBI recommends including with E-utilities requests
NCBI_TOOL_EMAIL=
